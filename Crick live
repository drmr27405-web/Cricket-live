index.html<!DOCTYPE html>  <html lang="en">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">  
    <title>CoverPoint · live cricket scores</title>  
    <style>  
        * {  
            margin: 0;  
            padding: 0;  
            box-sizing: border-box;  
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;  
        }  body {  
        background: #0a0c10;  
        color: #e8edf2;  
        line-height: 1.5;  
        min-height: 100vh;  
        display: flex;  
        flex-direction: column;  
    }  

    /* sticky header */  
    .header {  
        position: sticky;  
        top: 0;  
        z-index: 30;  
        background: #101318;  
        backdrop-filter: blur(6px);  
        border-bottom: 1px solid #2a2f38;  
        display: flex;  
        align-items: center;  
        justify-content: space-between;  
        padding: 0.9rem 1.2rem;  
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);  
    }  

    .logo-area {  
        display: flex;  
        align-items: center;  
        gap: 1rem;  
    }  

    .hamburger {  
        background: transparent;  
        border: none;  
        color: #34c759;  
        font-size: 2rem;  
        line-height: 1;  
        cursor: pointer;  
        width: 44px;  
        height: 44px;  
        display: flex;  
        align-items: center;  
        justify-content: center;  
        border-radius: 12px;  
        transition: background 0.2s;  
    }  
    .hamburger:hover { background: #262b34; }  

    .site-name {  
        font-size: 1.6rem;  
        font-weight: 700;  
        letter-spacing: -0.5px;  
        background: linear-gradient(145deg, #a6ffa6, #2ecc71);  
        -webkit-background-clip: text;  
        background-clip: text;  
        color: transparent;  
    }  

    .social-mini {  
        display: flex;  
        gap: 0.6rem;  
    }  
    .social-mini a {  
        color: #ccc;  
        text-decoration: none;  
        font-size: 1.3rem;  
    }  

    /* overlay & sidebar */  
    .sidebar-overlay {  
        position: fixed;  
        top: 0;  
        left: 0;  
        width: 100vw;  
        height: 100vh;  
        background: rgba(0,0,0,0.65);  
        backdrop-filter: blur(3px);  
        z-index: 100;  
        display: none;  
        transition: 0.2s;  
    }  
    .sidebar {  
        position: fixed;  
        top: 0;  
        left: -300px;  
        width: 280px;  
        height: 100vh;  
        background: #14181f;  
        border-right: 1px solid #2d3440;  
        padding: 2rem 0 2rem 1.8rem;  
        z-index: 110;  
        transition: left 0.25s ease-out;  
        box-shadow: 6px 0 20px #00000080;  
        overflow-y: auto;  
    }  
    .sidebar.open { left: 0; }  
    .sidebar-overlay.active { display: block; }  

    .sidebar-menu {  
        list-style: none;  
    }  
    .sidebar-menu li {  
        margin: 1.4rem 0;  
    }  
    .sidebar-menu a {  
        color: #cfd9e6;  
        text-decoration: none;  
        font-size: 1.2rem;  
        font-weight: 500;  
        display: inline-block;  
        padding: 0.4rem 1rem 0.4rem 0;  
        border-bottom: 2px solid transparent;  
        transition: 0.15s;  
    }  
    .sidebar-menu a:hover {  
        color: #5ced73;  
        border-bottom-color: #2ecc71;  
    }  

    /* main container */  
    .main-wrapper {  
        max-width: 1200px;  
        margin: 0 auto;  
        width: 100%;  
        flex: 1;  
        padding: 1rem 1rem 2rem;  
    }  

    /* ad placeholders (AdSense friendly) */  
    .ad-banner {  
        background: #1e232b;  
        border: 1px dashed #4a5c6e;  
        border-radius: 16px;  
        padding: 1.2rem;  
        margin: 1.5rem 0;  
        text-align: center;  
        color: #a0b3cc;  
        font-size: 1rem;  
        font-weight: 400;  
        letter-spacing: 0.5px;  
        box-shadow: inset 0 2px 6px #00000040;  
    }  
    .ad-banner::before {  
        content: "ⓘ ad";  
        display: block;  
        font-size: 0.75rem;  
        color: #6a7c94;  
        margin-bottom: 0.2rem;  
        text-transform: uppercase;  
    }  

    /* section headers */  
    .section-header {  
        font-size: 1.8rem;  
        font-weight: 700;  
        margin: 1.5rem 0 1.2rem 0;  
        border-left: 7px solid #34c759;  
        padding-left: 1rem;  
        background: linear-gradient(to right, #1f262e, transparent);  
    }  
    .live-badge {  
        display: inline-block;  
        background: #e03a3a;  
        color: white;  
        font-weight: 700;  
        font-size: 0.9rem;  
        padding: 0.2rem 0.9rem;  
        border-radius: 30px;  
        margin-left: 1rem;  
        vertical-align: middle;  
        box-shadow: 0 0 10px #ff4d4d;  
        animation: pulseGlow 1.7s infinite;  
    }  
    @keyframes pulseGlow { 0% { opacity: 1; } 50% { opacity: 0.7; } }  

    /* match cards grid */  
    .match-grid {  
        display: grid;  
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));  
        gap: 1.3rem;  
    }  

    /* card base */  
    .match-card {  
        background: #171c24;  
        border-radius: 28px;  
        padding: 1.4rem 1rem 1rem 1rem;  
        border: 1px solid #2d3846;  
        box-shadow: 0 8px 0 #0e1217;  
        transition: transform 0.15s, box-shadow 0.2s;  
    }  
    .match-card:hover { transform: translateY(-3px); box-shadow: 0 12px 0 #0b0e12; }  

    .completed-card {  
        opacity: 0.75;  
        filter: grayscale(0.3);  
        background: #131821;  
    }  

    /* flags & teams */  
    .team-row {  
        display: flex;  
        align-items: center;  
        justify-content: space-between;  
        margin: 0.6rem 0;  
    }  
    .team {  
        display: flex;  
        align-items: center;  
        gap: 0.5rem;  
        font-weight: 600;  
        font-size: 1.1rem;  
    }  
    .flag {  
        font-size: 2rem;  
        filter: drop-shadow(0 2px 4px black);  
    }  

    .match-meta {  
        color: #9eaaba;  
        font-size: 0.9rem;  
        border-top: 1px dashed #2f3b48;  
        margin-top: 0.8rem;  
        padding-top: 0.8rem;  
        display: flex;  
        justify-content: space-between;  
    }  

    .score-line {  
        background: #10161e;  
        border-radius: 24px;  
        padding: 0.7rem 1rem;  
        margin: 0.7rem 0;  
    }  

    .batting-highlight {  
        color: #ffd966;  
        font-weight: 700;  
        border-left: 4px solid #2ecc71;  
        padding-left: 0.5rem;  
    }  
    .bowler {  
        font-size: 0.9rem;  
        color: #b0c2d9;  
    }  
    .run-rate {  
        font-weight: 600;  
        color: #ffb347;  
    }  
    .live-indicator {  
        color: #ff4d4d;  
        font-weight: 800;  
        display: inline-block;  
        animation: blink 1.2s step-end infinite;  
    }  
    @keyframes blink { 0%,100%{ opacity:1 } 50%{ opacity:0.4 } }  

    .last-updated {  
        font-size: 0.7rem;  
        color: #667c99;  
        text-align: right;  
        margin-top: 0.4rem;  
    }  

    /* result tag */  
    .result-badge {  
        background: #28303b;  
        padding: 0.3rem 1rem;  
        border-radius: 30px;  
        font-size: 0.9rem;  
        color: #d4e2ff;  
        text-align: center;  
    }  

    /* footer social */  
    .footer-social {  
        background: #10151c;  
        border-radius: 40px;  
        padding: 1rem 1.8rem;  
        margin: 2.5rem 0 1rem;  
        display: flex;  
        flex-wrap: wrap;  
        align-items: center;  
        justify-content: center;  
        gap: 2rem;  
        border: 1px solid #263040;  
    }  
    .footer-social a {  
        color: #ddd;  
        text-decoration: none;  
        font-size: 1.2rem;  
        display: flex;  
        align-items: center;  
        gap: 6px;  
    }  
    .footer-social a:hover { color: #62ed7c; }  

    /* dynamic pages (legal) */  
    .legal-page {  
        background: #131a24;  
        border-radius: 28px;  
        padding: 2rem 2rem 2rem 2rem;  
        margin: 2rem 0;  
        border: 1px solid #2f4053;  
        display: none;  
    }  
    .legal-page.active-page {  
        display: block;  
    }  
    .legal-page h2 { color: #91ffa0; margin-bottom: 1rem; }  
    .legal-page p { margin: 1rem 0; color: #cbd5e6; }  

    /* mobile tight */  
    @media (max-width: 500px) {  
        .site-name { font-size: 1.3rem; }  
        .match-grid { grid-template-columns: 1fr; }  
        .social-mini { display: none; }  
    }  
</style>

</head>  
