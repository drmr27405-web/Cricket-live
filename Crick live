<script>  
    (function() {  
        // ----- MOCK DATA (AdSense safe, no external API) -----  
        const flags = { ind: '🇮🇳', aus: '🇦🇺', eng: '🏴', sa: '🇿🇦', nz: '🇳🇿', pak: '🇵🇰', sl: '🇱🇰', wi: '🏝️' };  

        // upcoming matches  
        const upcomingMatches = [  
            { teamA: 'India', teamB: 'Australia', flagA: flags.ind, flagB: flags.aus, date: '2025-04-12 15:30', tournament: 'IPL 2025' },  
            { teamA: 'England', teamB: 'New Zealand', flagA: flags.eng, flagB: flags.nz, date: '2025-04-13 10:00', tournament: 'ODI series' },  
            { teamA: 'South Africa', teamB: 'Pakistan', flagA: flags.sa, flagB: flags.pak, date: '2025-04-14 19:00', tournament: 'T20I' },  
            { teamA: 'West Indies', teamB: 'Sri Lanka', flagA: flags.wi, flagB: flags.sl, date: '2025-04-15 20:30', tournament: 'Test' },  
        ];  

        // live matches (will be updated)  
        let liveMatches = [  
            { teamA: 'India', teamB: 'Australia', flagA: flags.ind, flagB: flags.aus, batting: 'India', bowling: 'Australia', runsA: 158, wktsA: 4, oversA: 17.3, runsB: 0, wktsB: 0, oversB: 0.0, crr: 9.03, lastUpdate: new Date() },  
            { teamA: 'England', teamB: 'South Africa', flagA: flags.eng, flagB: flags.sa, batting: 'England', bowling: 'South Africa', runsA: 203, wktsA: 6, oversA: 19.2, runsB: 0, wktsB: 0, oversB: 0.0, crr: 10.5, lastUpdate: new Date() },  
            { teamA: 'NZ', teamB: 'SL', flagA: flags.nz, flagB: flags.sl, batting: 'NZ', bowling: 'SL', runsA: 112, wktsA: 2, oversA: 14.0, runsB: 0, wktsB: 0, oversB: 0.0, crr: 8.0, lastUpdate: new Date() }  
        ];  

        // completed matches  
        const completedMatches = [  
            { teamA: 'Australia', teamB: 'England', flagA: flags.aus, flagB: flags.eng, scoreA: '245/8 (50)', scoreB: '210 (44)', result: 'Australia won by 35 runs', tournament: 'World Cup' },  
            { teamA: 'Pakistan', teamB: 'India', flagA: flags.pak, flagB: flags.ind, scoreA: '167 (20)', scoreB: '168/4 (18.2)', result: 'India won by 6 wkts', tournament: 'T20 WC' }  
        ];  

        // render upcoming  
        function renderUpcoming() {  
            const container = document.getElementById('upcomingGrid');  
            if (!container) return;  
            container.innerHTML = upcomingMatches.map(m => `  
                <div class="match-card">  
                    <div class="team-row"><div class="team"><span class="flag">${m.flagA}</span> ${m.teamA}</div><div style="font-weight:bold;">vs</div><div class="team">${m.teamB} <span class="flag">${m.flagB}</span></div></div>  
                    <div class="match-meta"><span>${m.tournament}</span><span>${m.date}</span></div>  
                </div>  
            `).join('');  
        }  

        // render live (with animated scores)  
        function renderLive() {  
            const container = document.getElementById('liveGrid');  
            if (!container) return;  
            container.innerHTML = liveMatches.map(m => {  
                const battingTeam = m.batting === m.teamA ? m.teamA : m.teamB;  
                const bowlingTeam = m.batting === m.teamA ? m.teamB : m.teamA;  
                const runs = m.batting === m.teamA ? m.runsA : m.runsB;  
                const wkts = m.batting === m.teamA ? m.wktsA : m.wktsB;  
                const overs = m.batting === m.teamA ? m.oversA : m.oversB;  
                return `  
                <div class="match-card" style="border-left: 5px solid #2ecc71;">  
                    <div class="team-row"><div class="team"><span class="flag">${m.flagA}</span> ${m.teamA}</div><span class="live-indicator">● LIVE</span><div class="team">${m.teamB} <span class="flag">${m.flagB}</span></div></div>  
                    <div class="score-line">  
                        <div class="batting-highlight">${battingTeam} ▸ ${runs}/${wkts} (${overs} ov)</div>  
                        <div class="bowler">🎯 ${bowlingTeam} bowling</div>  
                        <div class="run-rate">CRR: ${m.crr}</div>  
                    </div>  
                    <div class="match-meta"><span>🏆 T20</span><span>⏱️ now</span></div>  
                </div>  
            `}).join('');  
            document.getElementById('liveUpdateStamp').innerText = 'last updated: ' + new Date().toLocaleTimeString();  
        }  

        // render completed  
        function renderCompleted() {  
            const container = document.getElementById('completedGrid');  
            if (!container) return;  
            container.innerHTML = completedMatches.map(m => `  
                <div class="match-card completed-card">  
                    <div class="team-row"><div class="team"><span class="flag">${m.flagA}</span> ${m.teamA}</div><div>🆚</div><div class="team">${m.teamB} <span class="flag">${m.flagB}</span></div></div>  
                    <div style="display:flex; justify-content:space-between; margin:0.6rem 0;"><span>${m.scoreA}</span><span>${m.scoreB}</span></div>  
                    <div class="result-badge">${m.result}</div>  
                    <div class="match-meta"><span>${m.tournament}</span><span>✅ finished</span></div>  
                </div>  
            `).join('');  
        }  

        // live score auto-update every 30 seconds (random realistic increments)  
        function updateLiveScores() {  
            liveMatches = liveMatches.map(m => {  
                const incRuns = Math.floor(Math.random() * 6) + 1;  // 1-6 runs  
                const incBall = 0.1; // simulate 0.1 over  
                let newOvers = (m.batting === m.teamA) ? m.oversA + 0.1 : m.oversB + 0.1;  
                if (newOvers > 20) newOvers = 20;  
                let newWkts = (Math.random() > 0.7 && ((m.batting === m.teamA && m.wktsA < 10) || (m.batting !== m.teamA && m.wktsB < 10))) ? 1 : 0;  
                if (m.batting === m.teamA) {  
                    return { ...m, runsA: m.runsA + incRuns, wktsA: Math.min(10, m.wktsA + newWkts), oversA: Math.round(newOvers * 10) / 10, crr: +( (m.runsA + incRuns) / newOvers ).toFixed(2), lastUpdate: new Date() };  
                } else {  
                    return { ...m, runsB: m.runsB + incRuns, wktsB: Math.min(10, m.wktsB + newWkts), oversB: Math.round(newOvers * 10) / 10, crr: +( (m.runsB + incRuns) / newOvers ).toFixed(2), lastUpdate: new Date() };  
                }  
            });  
            renderLive();  
        }  

        // sidebar toggle  
        const hamburger = document.getElementById('hamburgerBtn');  
        const sidebar = document.getElementById('sidebar');  
        const overlay = document.getElementById('sid
